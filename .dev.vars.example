# Optional LLM mode — copy this file to `.dev.vars` (gitignored) and add a real
# key. Deterministic mode is the default and works with NO keys, so this is only
# needed if you want to run scenarios through a live model.
#
# Anthropic is the supported live-model provider for this demo.

ANTHROPIC_API_KEY=

# Optional model override.
# Default: claude-sonnet-4-20250514
# LPL_MODEL=claude-sonnet-4-20250514
